# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ---------------------------------------------------------------------------

# --- Required credentials --------------------------------------------------
DISCORD_BOT_TOKEN=paste-your-discord-bot-token-here
GEMINI_API_KEY=paste-your-gemini-api-key-here

# --- External database (Turso / libSQL) ------------------------------------
# Set these to run the bot 24/7 on any host with a durable, external
# archive. Create them once with the Turso CLI:
#
#     turso db create mannully-bot
#     turso db show mannully-bot --url        # -> TURSO_DATABASE_URL
#     turso db tokens create mannully-bot     # -> TURSO_AUTH_TOKEN
#
# Leave BOTH blank to keep the original fully-local SQLite behaviour.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Optional tuning (sensible defaults; omit if unsure) -------------------
# DATABASE_FILE=history.db          # local file / embedded-replica cache
# GEMINI_MODEL=gemini-2.5-flash
# COMMAND_PREFIX=!
# SCRAPE_CHUNK_SIZE=100
# AUTO_SYNC_IF_EMPTY=false
# RAG_MAX_CONTEXT_MESSAGES=40
